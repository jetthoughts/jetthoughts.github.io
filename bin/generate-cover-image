#!/usr/bin/env bash
# Generate a minimalist hand-drawn blog cover (1200x630 JPEG) via gemini CLI.
#
# Pass the topic CONCEPT (not a literal scene) — the script bakes in the
# charcoal-on-cream minimalist style so every cover is consistent. Full
# design system: docs/projects/2510-seo-content-strategy/20-29-strategy/20.06-blog-cover-image-design-system.md
#
# Usage:
#   bin/generate-cover-image "pausing and resuming a long computation"
#   bin/generate-cover-image --slug <post-slug> "some concept"
#   bin/generate-cover-image --out /path/to/cover.jpg "some concept"
#   echo "some concept" | bin/generate-cover-image --slug <post-slug>
#   bin/generate-cover-image --dry-run "some concept"
#
# Flags:
#   --slug <slug>   Save to content/blog/<slug>/cover.jpg (overrides --out)
#   --out  <path>   Output path (default: ./cover.jpg)
#   --model <name>  Gemini model (default: gemini-2.5-flash-image aka Nano Banana)
#   --dry-run       Print the invocation without calling gemini
#   -h, --help      Show this help

set -euo pipefail

# -------- defaults --------
OUT_PATH=""
SLUG=""
MODEL="gemini-2.5-flash-image"
DRY_RUN=0
USER_PROMPT=""

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

usage() {
    # Print the comment block that follows the shebang, auto-stopping at
    # the first non-comment line. Avoids fragile hard-coded line numbers.
    awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
    exit "${1:-0}"
}

err() {
    echo "error: $*" >&2
    exit 1
}

# -------- arg parsing --------
while [[ $# -gt 0 ]]; do
    case $1 in
        --slug)
            [[ -n ${2:-} ]] || err "--slug requires a value"
            SLUG="$2"
            shift 2
            ;;
        --out)
            [[ -n ${2:-} ]] || err "--out requires a value"
            OUT_PATH="$2"
            shift 2
            ;;
        --model)
            [[ -n ${2:-} ]] || err "--model requires a value"
            MODEL="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        --)
            shift
            USER_PROMPT="${USER_PROMPT}${USER_PROMPT:+ }$*"
            break
            ;;
        -*)
            err "unknown flag: $1 (try --help)"
            ;;
        *)
            USER_PROMPT="${USER_PROMPT}${USER_PROMPT:+ }$1"
            shift
            ;;
    esac
done

# -------- read prompt from stdin if none given as arg --------
if [[ -z $USER_PROMPT && ! -t 0 ]]; then
    USER_PROMPT="$(cat)"
fi

[[ -n $USER_PROMPT ]] || err "no prompt provided (pass as arg or via stdin; try --help)"

# -------- resolve output path --------
if [[ -n $SLUG ]]; then
    OUT_PATH="${REPO_ROOT}/content/blog/${SLUG}/cover.jpg"
    # Ensure the post directory exists
    if [[ ! -d "${REPO_ROOT}/content/blog/${SLUG}" ]]; then
        err "post directory not found: content/blog/${SLUG} (pass --slug matching an existing post dir, or use --out instead)"
    fi
fi

if [[ -z $OUT_PATH ]]; then
    OUT_PATH="${PWD}/cover.jpg"
fi

# Normalize to absolute path so gemini's working-dir doesn't matter
case "$OUT_PATH" in
    /*) ABS_OUT="$OUT_PATH" ;;
    *)  ABS_OUT="${PWD}/$OUT_PATH" ;;
esac

OUT_DIR="$(dirname "$ABS_OUT")"
[[ -d "$OUT_DIR" ]] || err "output directory does not exist: $OUT_DIR"

# -------- validate gemini CLI --------
if ! command -v gemini >/dev/null 2>&1; then
    err "gemini CLI not found in PATH. Install via: npm install -g @google/gemini-cli"
fi

# -------- construct the enhanced prompt --------
# Locks the minimalist hand-drawn jt_site style so every cover is
# consistent regardless of how the user phrases the topic. Full rationale:
# docs/projects/2510-seo-content-strategy/20-29-strategy/20.06-blog-cover-image-design-system.md
read -r -d '' ENHANCED_PROMPT <<EOF || true
Generate one cover image (1200x630 JPEG) for a jetthoughts.com blog post.

STYLE: Minimalist hand-drawn digital sketch. Consistent 2-3pt charcoal (#333333) line art on cream background (#FFF9F0). Subtle paper grain. Slight hand-drawn imperfections — feels sketched in a notebook, not a CAD diagram.

COMPOSITION: Single focal point, rule of thirds or centered, 60-70% negative space, minimum 15% margin on all sides. One hero element only.

CONTENT: Translate the concept below into a physical, natural, or architectural VISUAL METAPHOR — not a literal depiction. Do not draw code, screens, terminals, keyboards, language logos, robots, gears, or lightbulbs (cliches). Think editorial illustration, not stock tech photography.

CONCEPT:
${USER_PROMPT}

PROHIBITIONS: No text, letters, numbers, or watermarks (the site overlays the title separately). No logos. No UI chrome. No neon or 3D.

OUTPUT: Save as JPEG at exactly this absolute path: ${ABS_OUT}

If no image generation tool is available, stop and print exactly: NO_IMAGE_TOOL_AVAILABLE
EOF

# -------- dry-run short-circuit --------
if [[ $DRY_RUN -eq 1 ]]; then
    echo "[dry-run] would invoke:"
    echo "  gemini -p '<enhanced prompt, ${#ENHANCED_PROMPT} chars>' \\"
    echo "         --model '$MODEL' \\"
    echo "         --approval-mode yolo \\"
    echo "         -o text"
    echo ""
    echo "[dry-run] output target: $ABS_OUT"
    echo ""
    echo "[dry-run] enhanced prompt preview:"
    echo "---"
    echo "$ENHANCED_PROMPT"
    echo "---"
    exit 0
fi

# -------- invoke gemini --------
echo "→ generating cover image via gemini CLI (model: $MODEL)"
echo "  target: $ABS_OUT"

# Remove any prior cover.jpg at that path so we can detect success unambiguously
[[ -f "$ABS_OUT" ]] && rm -f "$ABS_OUT"

# Run gemini in non-interactive YOLO mode. We capture output so we can
# report it on failure but do not mix it with the normal script stderr.
GEMINI_LOG="$(mktemp -t gemini-cover-image.XXXXXX.log)"
trap 'rm -f "$GEMINI_LOG"' EXIT

set +e
gemini \
    -p "$ENHANCED_PROMPT" \
    --model "$MODEL" \
    --approval-mode yolo \
    -o text \
    >"$GEMINI_LOG" 2>&1
GEMINI_EXIT=$?
set -e

# -------- validate output --------
if [[ $GEMINI_EXIT -ne 0 ]]; then
    echo "✗ gemini CLI exited with code $GEMINI_EXIT" >&2
    echo "--- gemini output ---" >&2
    tail -30 "$GEMINI_LOG" >&2
    echo "---" >&2
    exit "$GEMINI_EXIT"
fi

if grep -q "NO_IMAGE_TOOL_AVAILABLE" "$GEMINI_LOG"; then
    echo "✗ gemini CLI has no image generation tool available" >&2
    echo "  fix: install an image-gen extension (e.g., Imagen MCP server) or wire up Stitch" >&2
    exit 2
fi

if [[ ! -f "$ABS_OUT" ]]; then
    echo "✗ gemini ran but did not produce $ABS_OUT" >&2
    echo "--- gemini output (last 40 lines) ---" >&2
    tail -40 "$GEMINI_LOG" >&2
    echo "---" >&2
    exit 3
fi

# Verify the file is actually an image. macOS ships `file`; Linux too.
if command -v file >/dev/null 2>&1; then
    FILE_TYPE="$(file -b "$ABS_OUT")"
    case "$FILE_TYPE" in
        *JPEG*|*JPG*|*PNG*|*WebP*)
            ;;
        *)
            echo "✗ output file is not a recognized image: $FILE_TYPE" >&2
            echo "  path: $ABS_OUT" >&2
            exit 4
            ;;
    esac
fi

BYTES="$(wc -c <"$ABS_OUT" | tr -d ' ')"
echo "✓ cover image written: $ABS_OUT ($BYTES bytes)"

if [[ $BYTES -lt 5000 ]]; then
    echo "⚠ warning: file is only $BYTES bytes — may be a placeholder or error response" >&2
fi
