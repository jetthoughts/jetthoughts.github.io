#!/bin/sh
# Hugo 0.161+ invokes node with --allow-fs-read=node_modules/.bin flags
# (Node experimental --permission model). This denies postcss-import's
# fs.statSync calls on theme CSS files outside that path, breaking PostCSS.
#
# Bun ignores Node's --permission flags and resolves files normally.
# CI uses Hugo 0.160 + Bun and works without this shim. Local Homebrew
# Hugo 0.161+ needs it. CI-safe: bun also handles Node 0.160's invocations.
#
# Removed once Hugo permission flags become opt-out OR caniuse-api stops
# walking parent dirs for browserslist-stats.json.
exec bun "$@"
