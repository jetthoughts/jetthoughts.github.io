#!/usr/bin/env bash
# Simple Hugo build script

set -euo pipefail

# Default settings
OUTPUT_DIR=${OUTPUT_DIR:-_dest/public-dev}
ENVIRONMENT=${ENVIRONMENT:-development}

BASE_URL=${BASE_URL:-}

echo "Building Hugo site..."
echo "Environment: $ENVIRONMENT"
echo "Output: $OUTPUT_DIR"

BUILD_DRAFTS=${BUILD_DRAFTS:-}

# Hugo 0.161+ invokes node with --allow-fs-read flags that break PostCSS.
# bin/shims/node forwards to bun, which ignores Node's experimental
# permission model. See bin/shims/node for details.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PATH="$SCRIPT_DIR/shims:$SCRIPT_DIR/../node_modules/.bin:$PATH"
export PATH

HUGO_ARGS=(hugo build --noBuildLock --environment "$ENVIRONMENT" --destination "$OUTPUT_DIR")
[ -n "$BASE_URL" ] && HUGO_ARGS+=(--baseURL "$BASE_URL")
[ -n "$BUILD_DRAFTS" ] && HUGO_ARGS+=(--buildDrafts)

"${HUGO_ARGS[@]}"

echo "✓ Build complete"
